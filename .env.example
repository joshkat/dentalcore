# Copy to .env and adjust. NEVER commit .env.

# Database
DB_NAME=dentalcore
DB_USER=dentalcore
DB_PASSWORD=dentalcore

# Security — REQUIRED in production.
# Generate with: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=

# Initial admin (created on first start when the users table is empty)
ADMIN_EMAIL=admin@dentalcore.local
ADMIN_PASSWORD=change-me-admin-1

# URLs
FRONTEND_URL=http://localhost:5173
# Dev: comma-separated origin patterns (LAN devices included by default in compose).
# Prod compose pins this to FRONTEND_URL automatically.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.*.*:5173,http://10.*.*.*:5173,http://172.*.*.*:5173,http://*.local:5173

# Auth rate limit: max login/forgot-password requests per IP per minute
AUTH_RATE_LIMIT=15

# Seed demo dataset on startup (evaluation only — never in production)
SEED_DEMO_DATA=false
